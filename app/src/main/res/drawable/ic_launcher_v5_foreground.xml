            M82,40 L87,40 L87,46 L82,46 Z
            M28,50 L33,50 L33,56 L28,56 Z
            M35,50 L40,50 L40,56 L35,56 Z
            M42,50 L47,50 L47,56 L42,56 Z
            M49,50 L54,50 L54,56 L49,56 Z
            M56,50 L61,50 L61,56 L56,56 Z
            M63,50 L68,50 L68,56 L63,56 Z
            M70,50 L75,50 L75,56 L70,56 Z
            M77,50 L82,50 L82,56 L77,56 Z
            M26,60 L32,60 L32,66 L26,66 Z
            M35,60 L73,60 L73,66 L35,66 Z
