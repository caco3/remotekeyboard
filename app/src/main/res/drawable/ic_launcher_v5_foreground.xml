<!--
    Variant E: Teal + Simplified
    White keyboard body with teal key gaps.
    Simplified layout: 2 rows of 9 larger keys + spacebar row.
    Keys are 5×6dp (wider and taller) making them more visible at small sizes.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- White keyboard body -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M24,36 L84,36 Q90,36 90,42 L90,66 Q90,72 84,72 L24,72 Q18,72 18,66 L18,42 Q18,36 24,36 Z" />

    <!--
        Teal key gaps.
        Row 1: 9 keys, y=40–46 (6dp tall), step=7, start x=26
        Row 2: 8 keys, y=50–56 (6dp tall), step=7, start x=28 (staggered)
        Spacebar row: y=60–66, left key + wide spacebar + right key
    -->
    <path
        android:fillColor="#00695C"
        android:pathData="
            M26,40 L31,40 L31,46 L26,46 Z
            M33,40 L38,40 L38,46 L33,46 Z
            M40,40 L45,40 L45,46 L40,46 Z
