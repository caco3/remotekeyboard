<?xml version="1.0" encoding="utf-8"?>
<!--
    Foreground for the adaptive launcher icon.

    Geometry mirrors the SVG favicon embedded in
    @/home/gruinelli/CascadeProjects/remotekeyboard/app/src/main/assets/webclient.html
    (viewBox 0 0 64 64, white keyboard body 44×28 at (10,20), 6/5/5 keys + spacebar)
    so the app's launcher icon and the web client's favicon share an identical look.

    The favicon's 64-unit canvas is centred inside the 108×108 adaptive-icon
    foreground (offset = (108-64)/2 = 22) — i.e. all favicon coordinates are
    simply shifted by +22 in both axes. That keeps the design well within the
    66dp safe area and avoids clipping under any system mask (square, circle,
    squircle, teardrop).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- White keyboard body: favicon (10,20)-(54,48) rx=4, shifted by +22. -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M36,42 H72 Q76,42 76,46 V66 Q76,70 72,70 H36 Q32,70 32,66 V46 Q32,42 36,42 Z" />

    <!--
        Keys drawn in the same blue as the background (#1565C0) on top of the
        white body to simulate key gaps. Layout matches the favicon exactly:
          Row 1: 6 keys at y=46
          Row 2: 5 keys at y=52
          Row 3: 5 keys at y=58
          Row 4: spacebar at y=64
    -->
    <path
        android:fillColor="#1565C0"
        android:pathData="
            M36,46 H40 V50 H36 Z M43,46 H47 V50 H43 Z M50,46 H54 V50 H50 Z
            M57,46 H61 V50 H57 Z M64,46 H68 V50 H64 Z M71,46 H75 V50 H71 Z
            M38,52 H42 V56 H38 Z M45,52 H49 V56 H45 Z M52,52 H56 V56 H52 Z
            M59,52 H63 V56 H59 Z M66,52 H70 V56 H66 Z
            M40,58 H44 V62 H40 Z M47,58 H51 V62 H47 Z M54,58 H58 V62 H54 Z
            M61,58 H65 V62 H61 Z M68,58 H72 V62 H68 Z
            M42,64 H66 V68 H42 Z" />

</vector>
